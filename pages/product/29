<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="./styles/style3.css">
    <link rel="stylesheet" href="./styles/style4.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <title>Document</title>
</head>
<body>
 <div class="header-wrapper">
 <header class="header">
  <div class="header-left">
    <button class="icon">
      <svg class="icon-svg" viewBox="0 0 24 24">
        <path d="M3 6h18M3 12h18M3 18h18" />
      </svg>
    </button>

    <button class="icon">
      <svg class="icon-svg" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="7"/>
        <line x1="16.5" y1="16.5" x2="21" y2="21"/>
      </svg>
    </button>
  </div>

  <div class="header-center">
    <img src="img/elements/logo.png" alt="DS" class="logo-img">
  </div>

  <div class="header-right">
    <button class="icon">
      <svg class="icon-svg" viewBox="0 0 24 24">
        <path d="M6 8h12l-1.5 12h-9z"/>
        <path d="M9 8V6a3 3 0 0 1 6 0v2"/>
      </svg>
    </button>
    <div class="avatar"></div>
  </div>
 </header>
</div>   

<main class="product-page">
  <div class="product-container">
    
    <div class="product-gallery">
      <div class="image-wrapper">
        <button class="expand-btn">
          <svg viewBox="0 0 24 24"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke="currentColor" fill="none" stroke-width="2"/></svg>
        </button>
        <img src="img/product/london-edition.png" alt="London Edition Hoodie">
        <span class="image-counter">1/2</span>
      </div>
    </div>

    <div class="product-info">
      <h1 class="product-title">Exo Lummino - London Edition</h1>
      
      <div class="product-description">
        <h2 class="desc-heading">London Edition Hoodie - Street Style with British Character</h2>
        <p>Get into the big city with our limited edition London Edition hoodie. Deep red, Union Jack accents on the sleeves and a bold graffiti print create a powerful look with character.</p>
        <ul class="features-list">
          <li>Unique design with the inscription "Stay Confused" in graffiti style</li>
          <li>The London Edition signature is for those who feel the spirit of the metropolis</li>
          <li>Soft and warm fabric: perfect for cooler days</li>
          <li>Spacious kangaroo pocket for convenience and coziness</li>
          <li>Contrasting white cuffs and hem - a stylish highlight of the look</li>
        </ul>
      </div>

      <div class="product-controls">
        <div class="size-selector">
          <button class="size-btn">XS</button>
          <button class="size-btn active">M</button>
          <button class="size-btn">XL</button>
        </div>
        <button class="guide-btn">Order size</button>
      </div>

      <div class="purchase-actions">
        <button class="btn-buy">Buy now</button>
        <button class="btn-wishlist">In wish list</button>
      </div>
    </div>

  </div>
</main>
    
</body>
</html>